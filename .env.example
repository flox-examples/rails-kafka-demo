# Copy to .env.local and adjust. Sourced automatically by Devbox init_hook.
# Both repos share the same values — kafka-audit-service sources this file.

PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=

KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_POSTS_CREATED=posts.created
KAFKA_TOPIC_POSTS_PROCESSED=posts.processed
KAFKA_CONSUMER_GROUP=rails-kafka-demo

# URL of the kafka-audit-service (sibling repo running on port 3001)
AUDIT_SERVICE_URL=http://localhost:3001
